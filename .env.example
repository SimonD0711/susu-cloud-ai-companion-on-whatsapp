# ============================================================
# Susu Cloud вЂ?Environment Variables Template
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control!
# ============================================================

# в”Ђв”Ђ WhatsApp Business API в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Webhook verification token (set in Meta Developer Console)
WA_VERIFY_TOKEN=

# Long-lived User Access Token from Meta Developer Console
WA_ACCESS_TOKEN=

# Phone Number ID from Meta Developer Console
WA_PHONE_NUMBER_ID=

# WhatsApp Graph API version
WA_GRAPH_VERSION=v22.0

# в”Ђв”Ђ LLM Provider (Relay / Brain Bridge) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Required. Your relay API key for Claude requests.
WA_RELAY_API_KEY=

# Claude model for primary LLM calls. Default: claude-opus-4-6
WA_RELAY_MODEL=claude-opus-4-6

# Fallback Claude model when primary fails. Default: claude-sonnet-4-6
WA_RELAY_FALLBACK_MODEL=claude-sonnet-4-6

# Relay API base URL. Default: https://apiapipp.com/v1
WA_RELAY_BASE_URL=https://apiapipp.com/v1

# Optional override for auth header name. Default: Authorization
WA_RELAY_AUTH_HEADER=Authorization

# Optional full auth header value. Leave empty to use "Bearer ${WA_RELAY_API_KEY}".
WA_RELAY_AUTH_TOKEN=

# Optional second auth header, useful for gateways like Cloudflare AI Gateway.
WA_RELAY_EXTRA_AUTH_HEADER=
WA_RELAY_EXTRA_AUTH_TOKEN=

# Optional User-Agent override for relays/gateways with bot filtering.
WA_RELAY_USER_AGENT=

# Number of retries on relay failure. Default: 2
WA_RELAY_RETRY_COUNT=2

# Backoff delay between retries (seconds). Default: 1.0
WA_RELAY_RETRY_BACKOFF_SECONDS=1.0

# в”Ђв”Ђ Anthropic Native via Cloudflare AI Gateway в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Optional. If set, main chat path prefers Anthropic native /messages
# over the legacy OpenAI-compatible relay path.
WA_ANTHROPIC_GATEWAY_BASE_URL=
WA_ANTHROPIC_GATEWAY_TOKEN=
WA_ANTHROPIC_MODEL=claude-opus-4-6
WA_ANTHROPIC_VERSION=2023-06-01
WA_ANTHROPIC_USER_AGENT=Mozilla/5.0
WA_ANTHROPIC_WEB_SEARCH_ENABLED=1
WA_ANTHROPIC_WEB_SEARCH_MAX_USES=2

# в”Ђв”Ђ LLM Router (MiniMax Native) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Optional. If enabled, every inbound text first goes through a lightweight
# router model to decide whether live search is needed.
WA_ROUTER_ENABLED=1
WA_ROUTER_API_KEY=
WA_ROUTER_BASE_URL=https://api.minimaxi.com
WA_ROUTER_MODEL=MiniMax-M2.5-highspeed

# в”Ђв”Ђ Gemini (defined but currently unused) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
WA_GEMINI_API_KEY=
GOOGLE_KEY=
WA_GEMINI_MODEL=gemini-2.5-flash

# в”Ђв”Ђ MiniMax TTS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Required. MiniMax API key for voice synthesis.
WA_MINIMAX_API_KEY=

# MiniMax API base URL. Default: https://api.minimaxaxi.com/v1
WA_MINIMAX_BASE_URL=https://api.minimaxaxi.com/v1

# TTS voice ID. Default: Cantonese_CuteGirl
WA_TTS_VOICE_ID=Cantonese_CuteGirl

# TTS playback speed (0.5вЂ?.0). Default: 1.0
WA_TTS_SPEED=1.0

# в”Ђв”Ђ Whisper Transcription (Groq) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Groq API key (also accepts GROQ_API_KEY env var).
WA_GROQ_API_KEY=
GROQ_API_KEY=

# в”Ђв”Ђ Search & Live Data Providers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Tavily API key for web search.
WA_TAVILY_API_KEY=

# Bing Search API key.
WA_BING_API_KEY=

# YouTube Data API v3 key.
WA_YOUTUBE_API_KEY=

# X (Twitter) Bearer Token for social search.
WA_X_BEARER_TOKEN=

# Reddit user agent string. Default: SusuCloud/1.0
WA_REDDIT_USER_AGENT=SusuCloud/1.0

# OpenWeatherMap API key for weather queries.
WA_OPENWEATHER_API_KEY=

# Spotify API credentials for music search.
WA_SPOTIFY_CLIENT_ID=
WA_SPOTIFY_CLIENT_SECRET=

# в”Ђв”Ђ Proactive Messaging в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Set to 1 to enable, 0 to disable. Default: 1 (enabled)
WA_PROACTIVE_ENABLED=1

# How often to scan for proactive opportunities (seconds). Default: 300
WA_PROACTIVE_SCAN_SECONDS=300

# Minimum silence before sending a proactive message (minutes). Default: 45
WA_PROACTIVE_MIN_SILENCE_MINUTES=45

# Cooldown between proactive messages (minutes). Default: 180
WA_PROACTIVE_COOLDOWN_MINUTES=180

# Time window to reply to conversation starters (minutes). Default: 90
WA_PROACTIVE_REPLY_WINDOW_MINUTES=90

# Conversation window for proactive evaluation (hours). Default: 24
WA_PROACTIVE_CONVERSATION_WINDOW_HOURS=24

# Maximum proactive messages per service day. Default: 2
WA_PROACTIVE_MAX_PER_SERVICE_DAY=2

# Minimum inbound messages before proactive is triggered. Default: 8
WA_PROACTIVE_MIN_INBOUND_MESSAGES=8

# в”Ђв”Ђ WhatsApp Admin в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Primary WhatsApp user ID (phone number, no spaces).
WA_ADMIN_WA_ID=85259576670

# в”Ђв”Ђ Message Handling в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Maximum number of image attachments per message. Default: 3
WA_MAX_IMAGE_ATTACHMENTS=3

# Maximum image file size in bytes. Default: 5242880 (5 MB)
WA_MAX_IMAGE_BYTES=5242880

# Max inline reply emojis. Default: 1
WA_MAX_INLINE_REPLY_EMOJIS=1

# Delay before sending read receipt (seconds). Default: 0.45
WA_READ_RECEIPT_DELAY_SECONDS=0.45

# Typing indicator delay (seconds). Default: 0.5
WA_TYPING_INDICATOR_DELAY_SECONDS=0.5

# Typing indicator refresh interval (seconds). Default: 4.0
WA_TYPING_INDICATOR_REFRESH_SECONDS=4.0

# в”Ђв”Ђ Reply Worker в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Poll interval for reply job queue (seconds). Default: 0.05
WA_REPLY_JOB_POLL_SECONDS=0.05

# Grace period before terminating stale reply worker (seconds). Default: 0.25
WA_REPLY_JOB_TERMINATE_GRACE_SECONDS=0.25

# Mark reply worker as stale after (seconds). Default: 90
WA_REPLY_WORKER_STALE_SECONDS=90

# Recovery scan interval (seconds). Default: 30
WA_REPLY_RECOVERY_SCAN_SECONDS=30

# в”Ђв”Ђ Calendar (Google iCal) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Google Calendar iCal URL for schedule integration.
# Leave empty to disable calendar features.
WA_USER_ICAL_URL=

# в”Ђв”Ђ Admin Web Server в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Host to bind admin server. Default: 127.0.0.1 (localhost)
SUSU_ADMIN_HOST=127.0.0.1

# Port for admin web server. Default: 9001
SUSU_ADMIN_PORT=9001

# Display name shown on admin login page. Default: Admin
SUSU_ADMIN_DISPLAY_NAME=Admin

# Admin password salt (base64 encoded, min 16 chars).
# Generate with: python tools/hash_password.py "your-password"
SUSU_ADMIN_PASSWORD_SALT_B64=

# Admin password hash (base64 encoded, SHA-256).
# Generate with: python tools/hash_password.py "your-password"
SUSU_ADMIN_PASSWORD_HASH_B64=

# Secret key for signing session cookies (base64 encoded, min 32 chars).
# Generate with: python tools/hash_password.py "your-password"
SUSU_ADMIN_SESSION_SECRET=

# Session cookie name. Default: susu_admin_session
SUSU_ADMIN_SESSION_COOKIE=susu_admin_session

# Session TTL in seconds. Default: 2592000 (30 days)
SUSU_ADMIN_SESSION_TTL=2592000

# в”Ђв”Ђ Application Paths в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Base directory for application files.
# Default: /var/www/html (production) or . (development)
WA_BASE_DIR=/var/www/html

# SQLite database path. Default: WA_BASE_DIR/wa_agent.db
# Set empty to use default path.
WA_DB_PATH=

# в”Ђв”Ђ Susu Admin Base Directory в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Base directory for susu admin files (DB and HTML).
# Default: /var/www/html
SUSU_BASE_DIR=/var/www/html

