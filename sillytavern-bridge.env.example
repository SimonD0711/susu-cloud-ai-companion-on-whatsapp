# Enable the bridge-backed brain path in wa_agent.py
WA_BRAIN_PROVIDER=sillytavern
WA_BRAIN_FALLBACK_ON_ERROR=1
WA_SILLYTAVERN_API_URL=http://127.0.0.1:9102/v1/chat/completions
WA_SILLYTAVERN_API_KEY=replace-with-local-bridge-token
WA_SILLYTAVERN_MODEL=
WA_SILLYTAVERN_TIMEOUT_SECONDS=90

# Local bridge listener
WA_ST_BRIDGE_HOST=127.0.0.1
WA_ST_BRIDGE_PORT=9102
WA_ST_BRIDGE_API_KEY=replace-with-local-bridge-token

# Downstream backend behind the bridge
# Recommended:
# - agnai (Agnai-style structured backend)
# - openai (OpenAI-compatible chat/completions endpoint)
WA_ST_BRIDGE_UPSTREAM_MODE=agnai
WA_ST_BRIDGE_UPSTREAM_URL=http://127.0.0.1:8000/v1/chat/completions
WA_ST_BRIDGE_UPSTREAM_API_KEY=
WA_ST_BRIDGE_UPSTREAM_MODEL=
WA_ST_BRIDGE_TIMEOUT_SECONDS=90
WA_ST_BRIDGE_UPSTREAM_AUTH_HEADER=Authorization
